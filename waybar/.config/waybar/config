{
  "exclusive": true,
  "reload_style_on_change": true,
  "position": "top",
  "spacing": 4,
  "height": 28,
  "margin-top": 0,
  "width": 1440,
  "modules-left": [
    "group/left1", 
    "group/left2"
  ],
  "group/left1": {
    "orientation": "inherit",
    "modules": [
      "custom/menu",
      "clock",
      "idle_inhibitor",
      "custom/notification",
      "custom/updatespacman"
    ]
  },
  "group/left2": {
    "orientation": "inherit",
    "modules": ["tray"]
  },
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "mpris#spotatui",
    "mpris#cliamp",
    "mpris#spotify",
    "mpris#vlc",
    "mpris#mpv",
    "mpris#cider",
    "mpris#cmus",
    "mpris#celluloid",
    "group/right1"
  ],
  "group/right1": {
    "orientation": "inherit",
    "modules": [
      "backlight", 
      "network",
      "bluetooth",
      "pulseaudio#output",
      "pulseaudio#input",
      "power-profiles-daemon",
      "memory",
      "cpu",
      "battery"
    ]
  },
  "custom/menu": {
    "format": "󰜎",
    "on-click": "/home/once/.local/bin/fuzzel-power",
    "on-click-right": "kitty",
    "tooltip-format": "Power Menu"
  },
  "clock": {
    "format": "{:%H:%M  %d/%m/%Y}",
    "format-alt": "{:%L%d %B %Y}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-click-right": "mode",
      "format": {
        "month": "<span color='#ffead3'><b>{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>"
      }
    }
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    }
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "<span color='red'><sup></sup></span>",
      "none": "",
      "dnd-notification": "<span color='red'><sup></sup></span>",
      "dnd-none": "",
      "inhibited-notification": "<span color='red'><sup></sup></span>",
      "inhibited-none": "",
      "dnd-inhibited-notification": "<span color='red'><sup></sup></span>",
      "dnd-inhibited-none": ""
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/updatespacman": {
    "format": "{}{icon}",
    "return-type": "json",
    "format-icons": {
      "has-updates": " 󰏖",
      "updated": ""
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --no-zero-output"
  },
  "tray": {
    "icon-size": 12,
    "spacing": 4
  },
  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{icon}{windows}",
    "format-window-separator": " ",
