#!/usr/bin/env bash

# Kanagawa Dragon themed fuzzel power menu

# Options
lock="箚뙻  Lock"
logout="箚뛽  Logout"
suspend="箚쨪  Suspend"
reboot="箚몢  Reboot"
shutdown="箚맓  Shutdown"

menu_options="$lock\n$logout\n$suspend\n$reboot\n$shutdown"

# Calculate dynamic lines to prevent empty bottom space
options_count=$(echo -e "$menu_options" | grep -v -E '^$' | wc -l)
lines=$(( options_count < 10 ? options_count : 10 ))

# Launch fuzzel in dmenu mode
selected=$(echo -e "$menu_options" | fuzzel \
  --dmenu \
  --width=15 \
  --lines="$lines" \
  --prompt="Power  ")

case "$selected" in
    *Lock*)
        hyprlock
        ;;
    *Logout*)
        hyprctl dispatch 'hl.dsp.exit()' || loginctl terminate-user "$USER" || killall -9 Hyprland
        ;;
    *Suspend*)
        systemctl suspend
        ;;
    *Reboot*)
        systemctl reboot
        ;;
    *Shutdown*)
        systemctl poweroff
        ;;
esac
